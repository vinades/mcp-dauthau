# Copy file này sang .env (KHÔNG commit) để test wrapper local.
# Trong sử dụng thực tế, env nằm trong .mcp.json của AI client (Claude Code / Cursor).

# Bắt buộc — DauThau cấp khi đăng ký dịch vụ
DAUTHAU_APIKEY=<apikey-tu-tai-khoan-dauthau>
DAUTHAU_APISECRET=<apisecret-tu-tai-khoan-dauthau>
MCP_GATEWAY_URL=<url-gateway-duoc-cap>
MCP_GATEWAY_KEY=<gateway-key-duoc-cap>

# Tuỳ chọn — bỏ comment để override default
# DAUTHAU_HASH_ALGO=md5
# LOG_LEVEL=info
# MCP_GATEWAY_TIMEOUT_MS=30000
